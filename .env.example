# .env.example — 로컬 테스트용 (절대 커밋하지 마세요!)
# GitHub Repository Secrets에 동일한 키로 등록하세요.

# ── Claude API ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── 카카오/티스토리 계정 ─────────────────────────────
KAKAO_EMAIL=your_kakao_email@kakao.com
KAKAO_PASSWORD=your_kakao_password
TISTORY_BLOG=your-blog-name          # your-blog-name.tistory.com 에서 앞부분

# ── 카테고리 (선택) ───────────────────────────────────
TISTORY_CATEGORY_ID=0                # 0 = 미분류, 숫자는 티스토리 관리 페이지에서 확인

# ── Discord 알림 (선택) ───────────────────────────────
DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxxxx/yyyyy

# ── 기본 포스팅 주제 (스케줄 실행 시 사용) ───────────
# GitHub Variables (Secrets 아님)에 DEFAULT_TOPIC 으로 등록
# 예: "Python LangChain 최신 업데이트 정리"
